# Copie para .env (na raiz do repo) e preencha. O .env é ignorado pelo git.

# Tinker (Thinking Machines) — treino LoRA e inferência serverless
# Chave em: https://auth.thinkingmachines.ai/sign-up
TINKER_API_KEY=

# OpenAI — juiz de correção na validação (gpt-5.4)
OPENAI_API_KEY=

# OpenRouter — juiz RULER durante o treino (openrouter/openai/gpt-5.4-mini)
# Chave em: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Gemini — expansão sintética do dataset (opcional; há cache em JSON)
GEMINI_API_KEY=

# Hugging Face — publicação do modelo merged (opcional, seção 11 do treino)
HF_TOKEN=
